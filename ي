<style>
    /* ==================== GOOGLE FONTS ==================== */
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap');

    /* ==================== ROOT VARIABLES ==================== */
    :root {
        --primary-purple: #744379 !important;
        --primary-dark: #5a3560 !important;
        --primary-light: #a878b8 !important;
        --primary-pastel: #d4b5dd !important;
        --white: #ffffff !important;
        --text-dark: #1a1a2e !important;
        --text-gray: #6b7280 !important;
        --shadow-lg: 0 10px 25px -5px rgba(116, 67, 121, 0.2) !important;
    }

    * {
        margin: 0 !important;
        padding: 0 !important;
        box-sizing: border-box !important;
    }

    /* ==================== SMOOTH ANIMATIONS ==================== */
    @keyframes fadeIn {
        from {
            opacity: 0 !important;
        }
        to {
            opacity: 1 !important;
        }
    }

    @keyframes slideInDown {
        from {
            opacity: 0 !important;
            transform: translateY(-20px) !important;
        }
        to {
            opacity: 1 !important;
            transform: translateY(0) !important;
        }
    }

    @keyframes slideInUp {
        from {
            opacity: 0 !important;
            transform: translateY(20px) !important;
        }
        to {
            opacity: 1 !important;
            transform: translateY(0) !important;
        }
    }

    @keyframes scaleIn {
        from {
            opacity: 0 !important;
            transform: scale(0.95) !important;
        }
        to {
            opacity: 1 !important;
            transform: scale(1) !important;
        }
    }

    @keyframes floatSoft {
        0%, 100% {
            transform: translateY(0px) !important;
        }
        50% {
            transform: translateY(-8px) !important;
        }
    }

    /* ==================== SHAREPOINT CSS RESET ==================== */
    .ms-core-form-textbox,
    .ms-input,
    .ms-inputBox,
    .ms-TextField {
        all: revert !important;
    }

    /* ==================== MAIN CONTAINER ==================== */

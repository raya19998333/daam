                return this.on("input keydown keyup mousedown mouseup select contextmenu drop focusout", function(e) {
                    if (callback(this.value)) {
                        if (["keydown","mousedown","focusout"].indexOf(e.type) >= 0){
                            $(this).removeClass("input-error");
                            this.setCustomValidity("");
                        }
                        this.oldValue = this.value;
                        this.oldSelectionStart = this.selectionStart;
                        this.oldSelectionEnd = this.selectionEnd;
                    } else if (this.hasOwnProperty("oldValue")) {
                        $(this).addClass("input-error");
                        this.setCustomValidity(errMsg);
                        this.reportValidity();
                        this.value = this.oldValue;
                        this.setSelectionRange(this.oldSelectionStart, this.oldSelectionEnd);
                    } else {
                        this.value = "";
                    }
                });
            };
        }(jQuery));

        $(".MobileNumber").inputFilter(function(value) {
            return /^\d*$/.test(value) && (value === "" || parseInt(value) <= 99999999); 
        }, "Invalid");

        $(".browser").hide();

        if(getParameterByName("ar")=="y") {
            // RTL
        } else {
            $("#btnUploadFiles_DISC").attr("style","margin-top:-48px !important");
        }

        var URL = window.location.href;
        var FolderName_ = "";
        
        if(URL.indexOf("Lists/") > -1) {
            FolderName_ = URL.split("Lists/")[1].split("/")[0];
        }

        if(URL.indexOf("DispForm.aspx")>0) {
            $("#FileName_DISC").closest("div").hide();
            $("#btnUploadFiles_DISC").closest("div").hide();
            $(".attachment").hide();
        }

        var PID="";
        
        if(URL.indexOf("NewForm.aspx")>0) {
            PID = getParameterByName("PID");
            if(typeof itrateItems === 'function') {
                itrateItems(getParameterByName("PID"));
            }
        } else if(URL.indexOf("EditForm.aspx")>0 || URL.indexOf("DispForm.aspx")>0) {
            setTimeout(function() {
                if($("#PID").length) {
                    PID = $("#PID").val();
                    if(typeof itrateItems === 'function') {
                        itrateItems($("#PID").val());
                    }
                }
            }, 1000);
        }

        $( "#dialog-confirm" ).dialog({
            modal: true,
            resizable: false,
            height: "auto",
            width: 400,
            autoOpen: false,
            buttons: {
                "Delete": function(event) {
                    if(typeof DeleteCustomList === 'function') {
                        DeleteCustomList("FleetDoc", $("#DeleteDocID").val());
                    }
                    $( this ).dialog( "close" );
                },
                Cancel: function() {
                    $( this ).dialog( "close" );
                }
            }
        }); 

        $("#btnUploadFiles_DISC").click(function(){ 
            if($("#FileName_DISC").val() != "") { 
                if($("#inputTypeFiles_DISC").val() != "") {
                    $( "#DialogProgressBar" ).dialog( "open" );
                    if(typeof FileUpload === 'function') {
                        FileUpload(FolderName_);
                    }
                } else {
                    alert("Please attach the file");
                } 
            } else {
                alert("Attachment File Name is Required");
            }
        });

        if(document.getElementById("inputTypeFiles_DISC")) {
            document.getElementById("inputTypeFiles_DISC").addEventListener("change", function () {
                if (this.files.length > 0) {
                    const fileSize = this.files.item(0).size;
                    const fileMb = fileSize / 1024 ** 2;
                    if (fileMb >= 8) {
                        alert("Please select a file less than 8 MB.");
                        this.value = '';
                    }
                }
            });
        }
    });

    function MetaData(file) {
        updateObject = {
            __metadata: {
                type: file.ListItemAllFields.__metadata.type
            },
            Title: $("#FileName_DISC").val(),
            PID: $("#PID").length ? $("#PID").val() : ""
        };
        return updateObject;
    }

</script>
